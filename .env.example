# ==============================================================================
# MindPalace Agent Configuration
# ==============================================================================

# --- Global Default (Fallback) ---
# 如果未设置下方的特定任务配置，系统将默认回退使用以下设置。
# 支持任何 OpenAI 兼容 API (OpenAI, DeepSeek, Ollama, etc.)
OPENAI_API_KEY=sk-your-key-here
OPENAI_BASE_URL=https://api.openai.com/v1
# 支持多模型轮询，逗号分隔
MODEL_NAMES=gpt-4o-mini,gpt-4o

# --- Task-Specific Providers (Optional) ---
# 你可以为不同阶段配置不同的模型。删除或注释掉则使用 Global 设置。

# 1. Scout (抓取与启发性评分) - 推荐: DeepSeek (高性价比)
# SCOUT_API_KEY=sk-your-deepseek-key
# SCOUT_BASE_URL=https://api.deepseek.com/v1
# SCOUT_MODEL_NAMES=deepseek-chat

# 2. Council (智库议事厅讨论) - 推荐: Gemini 1.5 Pro / Claude (逻辑强)
# COUNCIL_API_KEY=your-gemini-key
# COUNCIL_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai
# COUNCIL_MODEL_NAMES=gemini-1.5-pro

# 3. Memory (心智画像分析) - 默认跟随 COUNCIL
# MEMORY_API_KEY=
# MEMORY_BASE_URL=
# MEMORY_MODEL_NAMES=

# 4. Fast (轻量后台任务：难度路由 / 记忆画像 / 压缩) - 推荐: DeepSeek / Qwen-Flash
# FAST_API_KEY=sk-your-deepseek-key
# FAST_BASE_URL=https://api.deepseek.com/v1
# FAST_MODEL_NAMES=deepseek-chat

# 5. Router (辩论难度路由) - 未设置时回落到 FAST
# ROUTER_API_KEY=
# ROUTER_BASE_URL=
# ROUTER_MODEL_NAMES=

# 6. Judge (辩论最终共识 + LLM-as-a-Judge 评估) - 推荐: Claude 3.5 Sonnet / DeepSeek-Reasoner
# 未设置时回落到 COUNCIL；Judge 是整轮辩论的质量守门员，推荐用第一梯队模型
# JUDGE_API_KEY=
# JUDGE_BASE_URL=
# JUDGE_MODEL_NAMES=claude-3-5-sonnet-20241022,deepseek-reasoner

# --- Council 辩论参数 ---
# 反驳循环的最大轮数。到达后强制落地 + 进入 Judge 收敛
# MAX_REBUTTAL_ROUNDS=3
# Judge midcheck 返回的 disagreement_score 低于此阈值时提前结束辩论
# CONVERGE_THRESHOLD=0.3

# 7. Embedding (文本向量化) - 默认: OpenAI text-embedding-3-small
# 未设置时回落到 OPENAI 凭据 + 默认模型 text-embedding-3-small
# EMBEDDING_API_KEY=
# EMBEDDING_BASE_URL=
# EMBEDDING_MODEL_NAMES=text-embedding-3-small

# --- Crystal 参数 ---
# 每累计多少条 memory 做一次认知画像结晶
# CRYSTAL_WINDOW=10

# --- Search 参数 ---
# Self-RAG 搜索提供者（默认 duckduckgo）
# SEARCH_PROVIDER=duckduckgo

# --- Observability (LLMOps) ---
# 启用 OpenTelemetry + Arize Phoenix 链路追踪（默认关闭）
# 启用后访问 http://localhost:6006 查看可视化面板
# 需先安装: pip install -e ".[obs]"
# TRACING_ENABLED=false

# --- Scout Feeds ---
# 默认抓取的 RSS 源，空格分隔或使用默认值
# FEEDS=https://hnrss.org/best http://arxiv.org/rss/cs.AI
