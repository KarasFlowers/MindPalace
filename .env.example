# ==============================================================================
# MindPalace Agent Configuration
# ==============================================================================

# --- Global Default (Fallback) ---
# 如果未设置下方的特定任务配置，系统将默认回退使用以下设置。
# PROVIDER_TYPE 控制底层协议：openai=OpenAI 兼容接口，anthropic=Anthropic Claude 官方接口
# 不填时会根据 BASE_URL 自动推断；使用中转/代理时通常保持 openai。
# OPENAI_PROVIDER_TYPE=openai
OPENAI_API_KEY=sk-your-key-here
OPENAI_BASE_URL=https://api.openai.com/v1
# 支持多模型轮询，逗号分隔。推荐统一使用 OPENAI_MODEL_NAMES
OPENAI_MODEL_NAMES=gpt-4o-mini,gpt-4o

# --- Reusable API Profiles (Recommended) ---
# 推荐先集中录入 API 档案，然后让各节点用 *_PROVIDER_PROFILE 选择档案。
# 档案名不区分大小写；例如 deepseek 会保存为 API_PROFILE_DEEPSEEK_*。
#
# API_PROFILE_DEEPSEEK_PROVIDER_TYPE=openai
# API_PROFILE_DEEPSEEK_API_KEY=sk-your-deepseek-key
# API_PROFILE_DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
# API_PROFILE_DEEPSEEK_MODEL_NAMES=deepseek-chat
#
# API_PROFILE_CLAUDE_PROVIDER_TYPE=anthropic
# API_PROFILE_CLAUDE_API_KEY=sk-ant-your-key
# API_PROFILE_CLAUDE_BASE_URL=https://api.anthropic.com/v1
# API_PROFILE_CLAUDE_MODEL_NAMES=claude-3-5-sonnet-20241022
#
# SCOUT_PROVIDER_PROFILE=deepseek
# COUNCIL_PROVIDER_PROFILE=claude
# JUDGE_PROVIDER_PROFILE=claude

# --- Task-Specific Providers (Optional) ---
# 你可以为不同阶段配置不同的模型。删除或注释掉则使用 Global 设置。
# 如果设置了 *_PROVIDER_PROFILE，会优先从对应 API_PROFILE_* 档案取值；
# 节点自己的 *_API_KEY / *_BASE_URL / *_MODEL_NAMES 仍可作为高级覆盖。

# 1. Scout (抓取与启发性评分) - 推荐: DeepSeek (高性价比)
# SCOUT_API_KEY=sk-your-deepseek-key
# SCOUT_BASE_URL=https://api.deepseek.com/v1
# SCOUT_MODEL_NAMES=deepseek-chat

# 2. Council (智库议事厅讨论) - 推荐: Gemini 1.5 Pro / Claude (逻辑强)
# COUNCIL_API_KEY=your-gemini-key
# COUNCIL_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai
# COUNCIL_MODEL_NAMES=gemini-1.5-pro
#
# Anthropic 官方 Claude 直连示例：
# COUNCIL_PROVIDER_TYPE=anthropic
# COUNCIL_API_KEY=sk-ant-your-key
# COUNCIL_BASE_URL=https://api.anthropic.com/v1
# COUNCIL_MODEL_NAMES=claude-3-5-sonnet-20241022

# 3. Memory (心智画像分析) - 未设置时默认回退到 Global Default
# MEMORY_API_KEY=
# MEMORY_BASE_URL=
# MEMORY_MODEL_NAMES=

# 4. Fast (轻量后台任务：难度路由 / 记忆画像 / 压缩) - 推荐: DeepSeek / Qwen-Flash
# FAST_API_KEY=sk-your-deepseek-key
# FAST_BASE_URL=https://api.deepseek.com/v1
# FAST_MODEL_NAMES=deepseek-chat

# 5. Router (辩论难度路由) - 未设置时回落到 FAST
# ROUTER_API_KEY=
# ROUTER_BASE_URL=
# ROUTER_MODEL_NAMES=

# 6. Judge (辩论最终共识 + LLM-as-a-Judge 评估) - 推荐: Claude 3.5 Sonnet / DeepSeek-Reasoner
# 未设置时回落到 COUNCIL；Judge 是整轮辩论的质量守门员，推荐用第一梯队模型
# JUDGE_API_KEY=
# JUDGE_BASE_URL=
# JUDGE_MODEL_NAMES=claude-3-5-sonnet-20241022,deepseek-reasoner

# --- Council 辩论参数 ---
# 反驳循环的最大轮数。到达后强制落地 + 进入 Judge 收敛
# MAX_REBUTTAL_ROUNDS=3
# Judge midcheck 返回的 disagreement_score 低于此阈值时提前结束辩论
# CONVERGE_THRESHOLD=0.3

# 7. Embedding (文本向量化) - 默认: OpenAI text-embedding-3-small
# 未设置时回落到 OPENAI 凭据 + 默认模型 text-embedding-3-small
# EMBEDDING_API_KEY=
# EMBEDDING_BASE_URL=
# EMBEDDING_MODEL_NAMES=text-embedding-3-small

# --- Crystal 参数 ---
# 每累计多少条 memory 做一次认知画像结晶
# CRYSTAL_WINDOW=10

# --- Search 参数 ---
# Self-RAG 搜索提供者（默认 duckduckgo）
# SEARCH_PROVIDER=duckduckgo

# --- Observability (LLMOps) ---
# 启用 OpenTelemetry + Arize Phoenix 链路追踪（默认关闭）
# 启用后访问 http://localhost:6006 查看可视化面板
# 需先安装: pip install -e ".[obs]"
# TRACING_ENABLED=false

# --- Scout Feeds ---
# 内容偏好预设：humanities（默认，人文社科优先）/ mixed / tech
# humanities 当前默认源：Aeon / Psyche / JSTOR Daily / The Point / Noema / Crooked Timber
# SCOUT_FEED_PRESET=humanities
#
# 如需完全自定义 RSS 源，可用空格 / 逗号 / 换行分隔
# SCOUT_FEEDS=https://aeon.co/feed.rss https://psyche.co/feed.rss
#
# 兼容旧变量名 FEEDS（不推荐新配置继续使用）
# FEEDS=https://hnrss.org/best http://arxiv.org/rss/cs.AI

# --- Article Library ---
# 自动清理超过保留期的普通文章；收藏文章、已讨论文章、已记忆文章默认保留
# ARTICLE_AUTO_CLEANUP=true
# ARTICLE_RETENTION_DAYS=30
